{
  "name": "skill-manager",
  "version": "1.0.0",
  "description": "CLI para instalar AI agent skills desde un repositorio local",
  "type": "module",
  "bin": {
    "skill-manager": "./bin/skill-manager.js",
    "skm": "./bin/skill-manager.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JavierSolis/skill-manager.git"
  },
  "homepage": "https://github.com/JavierSolis/skill-manager#readme",
  "bugs": {
    "url": "https://github.com/JavierSolis/skill-manager/issues"
  },
  "files": [
    "dist/",
    "bin/",
    "src/",
    "landing/",
    "README.md",
    "README-en.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "ai",
    "skills",
    "cli",
    "agent",
    "autoskills",
    "opencode",
    "claude"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --outDir dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "boxen": "^8.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.0.0",
    "ora": "^8.0.0",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.11",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
